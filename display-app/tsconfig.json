{
  "compilerOptions": {
    "target": "ES2020",
    "useDefineForClassFields": true,
    "lib": ["ES2020", "DOM", "DOM.Iterable"],
    "module": "ESNext",
    "skipLibCheck": true,

    /* Bundler mode */
    "moduleResolution": "bundler",
    "allowImportingTsExtensions": true,
    "resolveJsonModule": true,
    "isolatedModules": true,
    "moduleDetection": "force",
    "noEmit": true,
    "jsx": "react-jsx",

    /* Linting */
    "strict": true,
    "noUnusedLocals": true,
    "noUnusedParameters": true,
    "noFallthroughCasesInSwitch": true,

    /* Test globals + node builtins used in tests/config */
    "types": ["vitest/globals", "node"],

    /* Neutral top-level shared/ engine + display logic (SC1). */
    "baseUrl": ".",
    "paths": {
      "@quantum/*": ["../shared/quantum/*"],
      "@shared/*": ["../shared/*"],
      // shared/ has no node_modules of its own — resolve the bare packages it
      // imports from this app's node_modules so `tsc --noEmit` can type-check
      // the shared sources. React is mapped to its `@types` declarations (this
      // build only type-checks; vite does the runtime bundling).
      "react": ["./node_modules/@types/react"],
      "react/*": ["./node_modules/@types/react/*"],
      "@qamposer/react": ["./node_modules/@qamposer/react"],
      "@testing-library/react": ["./node_modules/@testing-library/react"]
    }
  },
  "include": ["src", "vite.config.ts"]
}
